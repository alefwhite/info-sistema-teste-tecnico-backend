# Application Configuration
NODE_ENV=development
PORT=3000

# Database Provider ('inmemory' or 'typeorm')
DATABASE_PROVIDER=inmemory

# TypeORM Database Configuration
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrong@Pass123
DB_NAME=fleet_db

# JWT Configuration
JWT_SECRET=your-secret-key-must-be-very-long-and-secure
JWT_EXPIRES_IN=7d

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL=3600

# RabbitMQ (if enabled)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Seed Configuration
DEFAULT_USER_PASSWORD=aivacol_admin_password

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/fleet_audit

